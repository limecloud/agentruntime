{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentruntime.example/schemas/agentruntime-event.schema.json",
  "title": "Agent Runtime event",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "type",
    "eventId",
    "timestamp"
  ],
  "properties": {
    "type": {
      "type": "string",
      "enum": [
        "session.created",
        "session.updated",
        "thread.started",
        "thread.updated",
        "turn.submitted",
        "turn.started",
        "turn.completed",
        "turn.failed",
        "task.created",
        "task.accepted",
        "task.queued",
        "task.started",
        "task.updated",
        "task.progress",
        "task.waiting",
        "task.blocked",
        "task.paused",
        "task.resumed",
        "task.retrying",
        "task.cancel_requested",
        "task.cancelled",
        "task.timed_out",
        "task.failed",
        "task.lost",
        "task.completed",
        "task.archived",
        "run.status",
        "model.requested",
        "model.delta",
        "model.completed",
        "model.failed",
        "reasoning.delta",
        "reasoning.summary",
        "tool.catalog.resolved",
        "tool.started",
        "tool.args",
        "tool.progress",
        "tool.result",
        "tool.failed",
        "action.required",
        "action.resolved",
        "queue.changed",
        "context.resolved",
        "context.compaction.started",
        "context.compaction.completed",
        "context.compaction.failed",
        "artifact.changed",
        "evidence.changed",
        "subagent.spawned",
        "subagent.status",
        "subagent.input",
        "subagent.completed",
        "subagent.failed",
        "subagent.closed",
        "limit.changed",
        "snapshot.updated",
        "runtime.warning",
        "runtime.error",
        "permission.evaluated",
        "permission.requested",
        "permission.resolved",
        "sandbox.applied",
        "sandbox.violation",
        "hook.started",
        "hook.completed",
        "hook.failed",
        "policy.changed",
        "process.started",
        "process.output",
        "process.input",
        "process.completed",
        "process.failed",
        "process.terminated",
        "task.profile.resolved",
        "routing.candidates.resolved",
        "routing.decided",
        "routing.fallback.applied",
        "routing.not_possible",
        "routing.single_candidate",
        "task.delegated",
        "task.dependency.updated",
        "task.attempt.started",
        "task.attempt.completed",
        "task.attempt.failed",
        "cost.estimated",
        "cost.recorded",
        "rate_limit.hit",
        "quota.low",
        "quota.blocked",
        "channel.connected",
        "channel.disconnected",
        "channel.resumed",
        "channel.message",
        "channel.permission_forwarded",
        "channel.permission_returned",
        "job.created",
        "job.started",
        "job.progress",
        "job.item.started",
        "job.item.completed",
        "job.item.failed",
        "job.completed",
        "job.failed",
        "job.cancelled",
        "output.spilled",
        "output.truncated",
        "output.redacted",
        "output.expired",
        "history.window.loaded",
        "history.reconstructed",
        "history.rollback.started",
        "history.rollback.completed",
        "snapshot.repaired",
        "benchmark.dataset.resolved",
        "benchmark.configuration.resolved",
        "benchmark.trial.started",
        "benchmark.trial.completed",
        "benchmark.trial.failed",
        "benchmark.reward.recorded",
        "benchmark.comparison.completed"
      ]
    },
    "eventId": {
      "type": "string",
      "minLength": 1
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "schemaVersion": {
      "type": "string"
    },
    "runtimeId": {
      "type": "string"
    },
    "sessionId": {
      "type": "string",
      "minLength": 1
    },
    "threadId": {
      "type": "string",
      "minLength": 1
    },
    "turnId": {
      "type": "string",
      "minLength": 1
    },
    "taskId": {
      "type": "string",
      "minLength": 1
    },
    "runId": {
      "type": "string",
      "minLength": 1
    },
    "attemptId": {
      "type": "string",
      "minLength": 1
    },
    "parentTaskId": {
      "type": "string",
      "minLength": 1
    },
    "rootTaskId": {
      "type": "string",
      "minLength": 1
    },
    "task": {
      "type": "object",
      "additionalProperties": true
    },
    "taskAttempt": {
      "type": "object",
      "additionalProperties": true
    },
    "taskRelationship": {
      "type": "object",
      "additionalProperties": true
    },
    "taskGraph": {
      "type": "object",
      "additionalProperties": true
    },
    "taskProgress": {
      "type": "object",
      "additionalProperties": true
    },
    "taskAcceptance": {
      "type": "object",
      "additionalProperties": true
    },
    "worker": {
      "type": "object",
      "additionalProperties": true
    },
    "deliveryState": {
      "type": "object",
      "additionalProperties": true
    },
    "nativeStatus": {
      "type": "string"
    },
    "stepId": {
      "type": "string",
      "minLength": 1
    },
    "toolCallId": {
      "type": "string",
      "minLength": 1
    },
    "actionId": {
      "type": "string",
      "minLength": 1
    },
    "subagentId": {
      "type": "string",
      "minLength": 1
    },
    "artifactId": {
      "type": "string",
      "minLength": 1
    },
    "evidenceId": {
      "type": "string",
      "minLength": 1
    },
    "traceId": {
      "type": "string"
    },
    "spanId": {
      "type": "string"
    },
    "sequence": {
      "type": "integer",
      "minimum": 0
    },
    "status": {
      "type": "string"
    },
    "phase": {
      "type": "string"
    },
    "payload": {
      "type": [
        "object",
        "array",
        "string",
        "number",
        "boolean",
        "null"
      ]
    },
    "refs": {
      "type": "object",
      "additionalProperties": true
    },
    "requestId": {
      "type": "string",
      "minLength": 1
    },
    "processId": {
      "type": "string",
      "minLength": 1
    },
    "channelId": {
      "type": "string",
      "minLength": 1
    },
    "jobId": {
      "type": "string",
      "minLength": 1
    },
    "jobItemId": {
      "type": "string",
      "minLength": 1
    },
    "outputRef": {
      "type": "string",
      "minLength": 1
    },
    "modelRequestId": {
      "type": "string",
      "minLength": 1
    },
    "queueId": {
      "type": "string",
      "minLength": 1
    },
    "permissionDecision": {
      "type": "object",
      "additionalProperties": true
    },
    "sandboxProfile": {
      "type": "object",
      "additionalProperties": true
    },
    "routingDecision": {
      "type": "object",
      "additionalProperties": true
    },
    "candidateModelSet": {
      "type": "object",
      "additionalProperties": true
    },
    "taskProfile": {
      "type": "object",
      "additionalProperties": true
    },
    "limitState": {
      "type": "object",
      "additionalProperties": true
    },
    "limitEvent": {
      "type": "object",
      "additionalProperties": true
    },
    "costState": {
      "type": "object",
      "additionalProperties": true
    },
    "hookRun": {
      "type": "object",
      "additionalProperties": true
    },
    "executionEnvironment": {
      "type": "object",
      "additionalProperties": true
    },
    "channel": {
      "type": "object",
      "additionalProperties": true
    },
    "job": {
      "type": "object",
      "additionalProperties": true
    },
    "jobItem": {
      "type": "object",
      "additionalProperties": true
    },
    "output": {
      "type": "object",
      "additionalProperties": true
    },
    "historyBoundary": {
      "type": "object",
      "additionalProperties": true
    },
    "telemetry": {
      "type": "object",
      "additionalProperties": true
    },
    "correlation": {
      "type": "object",
      "additionalProperties": true
    },
    "statusReason": {
      "type": "string"
    },
    "benchmark": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "datasetId": {
          "type": "string"
        },
        "datasetVersion": {
          "type": "string"
        },
        "datasetRef": {
          "type": "string"
        },
        "taskId": {
          "type": "string"
        },
        "trialId": {
          "type": "string"
        },
        "configurationId": {
          "type": "string"
        },
        "role": {
          "enum": [
            "baseline",
            "candidate",
            "control"
          ]
        },
        "harborJobRef": {
          "type": "string"
        },
        "harborTrialRef": {
          "type": "string"
        },
        "singleChangedVariable": {
          "type": "string"
        }
      }
    },
    "trajectory": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "schema": {
          "type": "string"
        },
        "ref": {
          "type": "string"
        },
        "exportStatus": {
          "enum": [
            "pending",
            "exported",
            "failed",
            "redacted",
            "not-supported"
          ]
        },
        "requiredFieldStatus": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "reward": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "value": {
          "type": "number"
        },
        "ref": {
          "type": "string"
        },
        "detailsRef": {
          "type": "string"
        },
        "criteria": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "failureCategory": {
          "type": "string"
        }
      }
    },
    "comparison": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "meanRewardDelta": {
          "type": "number"
        },
        "timeoutRateDelta": {
          "type": "number"
        },
        "evidenceCompletenessRate": {
          "type": "number"
        },
        "p0QcGateRegressionCount": {
          "type": "integer",
          "minimum": 0
        },
        "decision": {
          "type": "string"
        }
      }
    }
  }
}
