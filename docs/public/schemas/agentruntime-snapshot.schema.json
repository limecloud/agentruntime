{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentruntime.example/schemas/agentruntime-snapshot.schema.json",
  "title": "Agent Runtime snapshot",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schemaVersion",
    "sessionId",
    "threads"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string"
    },
    "sessionId": {
      "type": "string",
      "minLength": 1
    },
    "workspaceId": {
      "type": "string"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "threads": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/thread"
      }
    },
    "toolInventoryRef": {
      "type": "string"
    },
    "evidenceRefs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "executionEnvironment": {
      "type": "object",
      "additionalProperties": true
    },
    "permissionState": {
      "type": "object",
      "additionalProperties": true
    },
    "sandboxState": {
      "type": "object",
      "additionalProperties": true
    },
    "routingLimitSummary": {
      "type": "object",
      "additionalProperties": true
    },
    "subagentJobSummary": {
      "type": "object",
      "additionalProperties": true
    },
    "channelSummary": {
      "type": "object",
      "additionalProperties": true
    },
    "telemetrySummary": {
      "type": "object",
      "additionalProperties": true
    },
    "outputSummary": {
      "type": "object",
      "additionalProperties": true
    },
    "historySummary": {
      "type": "object",
      "additionalProperties": true
    },
    "taskSummary": {
      "type": "object",
      "additionalProperties": true
    },
    "tasks": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/task"
      }
    },
    "taskGraph": {
      "type": "object",
      "additionalProperties": true
    },
    "blockedTasks": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "deliveryState": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "$defs": {
    "thread": {
      "type": "object",
      "required": [
        "threadId",
        "status"
      ],
      "properties": {
        "threadId": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": [
            "idle",
            "queued",
            "running",
            "blocked",
            "completed",
            "failed",
            "cancelled",
            "stale",
            "unknown"
          ]
        },
        "activeTurnId": {
          "type": "string"
        },
        "turns": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/turn"
          }
        },
        "pendingRequests": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "queuedTurns": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "incidents": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "actions": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "toolCalls": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "processes": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "permissionState": {
          "type": "object",
          "additionalProperties": true
        },
        "sandboxState": {
          "type": "object",
          "additionalProperties": true
        },
        "modelRouting": {
          "type": "object",
          "additionalProperties": true
        },
        "limitState": {
          "type": "object",
          "additionalProperties": true
        },
        "costState": {
          "type": "object",
          "additionalProperties": true
        },
        "subagents": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "jobs": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "channels": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "telemetry": {
          "type": "object",
          "additionalProperties": true
        },
        "history": {
          "type": "object",
          "additionalProperties": true
        },
        "outputs": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "evidenceSummary": {
          "type": "object",
          "additionalProperties": true
        },
        "tasks": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/task"
          }
        },
        "taskGraph": {
          "type": "object",
          "additionalProperties": true
        },
        "blockedTasks": {
          "type": "array",
          "items": {
            "type": "object"
          }
        }
      }
    },
    "turn": {
      "type": "object",
      "required": [
        "turnId",
        "status"
      ],
      "properties": {
        "turnId": {
          "type": "string"
        },
        "status": {
          "type": "string"
        },
        "startedAt": {
          "type": "string",
          "format": "date-time"
        },
        "completedAt": {
          "type": "string",
          "format": "date-time"
        },
        "steps": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "taskProfile": {
          "type": "object",
          "additionalProperties": true
        },
        "routingDecision": {
          "type": "object",
          "additionalProperties": true
        },
        "candidateModelSet": {
          "type": "object",
          "additionalProperties": true
        },
        "permissionState": {
          "type": "object",
          "additionalProperties": true
        },
        "sandboxProfile": {
          "type": "object",
          "additionalProperties": true
        },
        "executionEnvironment": {
          "type": "object",
          "additionalProperties": true
        },
        "costState": {
          "type": "object",
          "additionalProperties": true
        },
        "limitState": {
          "type": "object",
          "additionalProperties": true
        },
        "hookRuns": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "processes": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "outputRefs": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "taskId": {
          "type": "string"
        },
        "runId": {
          "type": "string"
        },
        "attemptId": {
          "type": "string"
        },
        "tasks": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/task"
          }
        }
      }
    },
    "statusValue": {
      "type": "string",
      "enum": [
        "idle",
        "queued",
        "preparing",
        "running",
        "blocked",
        "streaming",
        "retrying",
        "completed",
        "failed",
        "cancelled",
        "stale",
        "unknown",
        "unavailable",
        "not_applicable"
      ]
    },
    "taskStatusValue": {
      "type": "string",
      "enum": [
        "draft",
        "accepted",
        "queued",
        "preparing",
        "running",
        "waiting_input",
        "waiting_permission",
        "waiting_resource",
        "blocked",
        "paused",
        "retrying",
        "cancelling",
        "cancelled",
        "timed_out",
        "failed",
        "lost",
        "completed",
        "archived",
        "stale",
        "unknown"
      ]
    },
    "taskAttempt": {
      "type": "object",
      "required": [
        "runId",
        "status"
      ],
      "properties": {
        "runId": {
          "type": "string"
        },
        "attemptId": {
          "type": "string"
        },
        "status": {
          "$ref": "#/$defs/statusValue"
        },
        "worker": {
          "type": "object",
          "additionalProperties": true
        },
        "inputRefs": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "outputRefs": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "checkpointRefs": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "startedAt": {
          "type": "string",
          "format": "date-time"
        },
        "endedAt": {
          "type": "string",
          "format": "date-time"
        },
        "attemptCount": {
          "type": "integer",
          "minimum": 0
        },
        "retryPolicy": {
          "type": "object",
          "additionalProperties": true
        },
        "lastError": {
          "type": "object",
          "additionalProperties": true
        },
        "completionSummary": {
          "type": "string"
        }
      }
    },
    "taskRelationship": {
      "type": "object",
      "required": [
        "kind",
        "targetId"
      ],
      "properties": {
        "kind": {
          "type": "string"
        },
        "targetId": {
          "type": "string"
        },
        "status": {
          "type": "string"
        },
        "reason": {
          "type": "string"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "task": {
      "type": "object",
      "required": [
        "taskId",
        "status"
      ],
      "properties": {
        "taskId": {
          "type": "string"
        },
        "parentTaskId": {
          "type": "string"
        },
        "rootTaskId": {
          "type": "string"
        },
        "sessionId": {
          "type": "string"
        },
        "threadId": {
          "type": "string"
        },
        "turnId": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "objective": {
          "type": "string"
        },
        "taskKind": {
          "type": "string"
        },
        "taskFamily": {
          "type": "string"
        },
        "visibility": {
          "type": "string",
          "enum": [
            "foreground",
            "background",
            "internal",
            "hidden",
            "unknown"
          ]
        },
        "status": {
          "$ref": "#/$defs/taskStatusValue"
        },
        "nativeStatus": {
          "type": "string"
        },
        "priority": {
          "type": "string"
        },
        "requestedBy": {
          "type": "object",
          "additionalProperties": true
        },
        "owner": {
          "type": "object",
          "additionalProperties": true
        },
        "assignee": {
          "type": "object",
          "additionalProperties": true
        },
        "scope": {
          "type": "object",
          "additionalProperties": true
        },
        "constraints": {
          "type": "object",
          "additionalProperties": true
        },
        "taskProfile": {
          "type": "object",
          "additionalProperties": true
        },
        "acceptance": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "progress": {
          "type": "object",
          "additionalProperties": true
        },
        "currentRunId": {
          "type": "string"
        },
        "attempts": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/taskAttempt"
          }
        },
        "relationships": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/taskRelationship"
          }
        },
        "artifacts": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "evidenceRefs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "deliveryState": {
          "type": "object",
          "additionalProperties": true
        },
        "lastError": {
          "type": "object",
          "additionalProperties": true
        },
        "statusReason": {
          "type": "string"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        },
        "startedAt": {
          "type": "string",
          "format": "date-time"
        },
        "endedAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    }
  }
}
