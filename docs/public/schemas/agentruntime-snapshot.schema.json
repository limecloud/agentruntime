{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentruntime.example/schemas/agentruntime-snapshot.schema.json",
  "title": "Agent Runtime snapshot",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schemaVersion",
    "sessionId",
    "threads"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string"
    },
    "sessionId": {
      "type": "string",
      "minLength": 1
    },
    "workspaceId": {
      "type": "string"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "threads": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/thread"
      }
    },
    "toolInventoryRef": {
      "type": "string"
    },
    "evidenceRefs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "executionEnvironment": {
      "type": "object",
      "additionalProperties": true
    },
    "permissionState": {
      "type": "object",
      "additionalProperties": true
    },
    "sandboxState": {
      "type": "object",
      "additionalProperties": true
    },
    "routingLimitSummary": {
      "type": "object",
      "additionalProperties": true
    },
    "subagentJobSummary": {
      "type": "object",
      "additionalProperties": true
    },
    "channelSummary": {
      "type": "object",
      "additionalProperties": true
    },
    "telemetrySummary": {
      "type": "object",
      "additionalProperties": true
    },
    "outputSummary": {
      "type": "object",
      "additionalProperties": true
    },
    "historySummary": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "$defs": {
    "thread": {
      "type": "object",
      "required": [
        "threadId",
        "status"
      ],
      "properties": {
        "threadId": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": [
            "idle",
            "queued",
            "running",
            "blocked",
            "completed",
            "failed",
            "cancelled",
            "stale",
            "unknown"
          ]
        },
        "activeTurnId": {
          "type": "string"
        },
        "turns": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/turn"
          }
        },
        "pendingRequests": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "queuedTurns": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "incidents": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "actions": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "toolCalls": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "processes": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "permissionState": {
          "type": "object",
          "additionalProperties": true
        },
        "sandboxState": {
          "type": "object",
          "additionalProperties": true
        },
        "modelRouting": {
          "type": "object",
          "additionalProperties": true
        },
        "limitState": {
          "type": "object",
          "additionalProperties": true
        },
        "costState": {
          "type": "object",
          "additionalProperties": true
        },
        "subagents": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "jobs": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "channels": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "telemetry": {
          "type": "object",
          "additionalProperties": true
        },
        "history": {
          "type": "object",
          "additionalProperties": true
        },
        "outputs": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "evidenceSummary": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "turn": {
      "type": "object",
      "required": [
        "turnId",
        "status"
      ],
      "properties": {
        "turnId": {
          "type": "string"
        },
        "status": {
          "type": "string"
        },
        "startedAt": {
          "type": "string",
          "format": "date-time"
        },
        "completedAt": {
          "type": "string",
          "format": "date-time"
        },
        "steps": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "taskProfile": {
          "type": "object",
          "additionalProperties": true
        },
        "routingDecision": {
          "type": "object",
          "additionalProperties": true
        },
        "candidateModelSet": {
          "type": "object",
          "additionalProperties": true
        },
        "permissionState": {
          "type": "object",
          "additionalProperties": true
        },
        "sandboxProfile": {
          "type": "object",
          "additionalProperties": true
        },
        "executionEnvironment": {
          "type": "object",
          "additionalProperties": true
        },
        "costState": {
          "type": "object",
          "additionalProperties": true
        },
        "limitState": {
          "type": "object",
          "additionalProperties": true
        },
        "hookRuns": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "processes": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "outputRefs": {
          "type": "array",
          "items": {
            "type": "object"
          }
        }
      }
    },
    "statusValue": {
      "type": "string",
      "enum": [
        "idle",
        "queued",
        "preparing",
        "running",
        "blocked",
        "streaming",
        "retrying",
        "completed",
        "failed",
        "cancelled",
        "stale",
        "unknown",
        "unavailable",
        "not_applicable"
      ]
    }
  }
}
